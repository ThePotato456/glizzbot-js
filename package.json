{
  "name": "glizzbot-js",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "test:coverage": "tsx --test --experimental-test-coverage --test-coverage-lines=75 --test-coverage-branches=70 --test-coverage-functions=75 test/**/*.test.ts",
    "test:watch": "tsx watch --test test/**/*.test.ts"
  },
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "@noble/ciphers": "^2.2.0",
    "@snazzah/davey": "^0.1.12",
    "discord.js": "^14.21.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "opusscript": "^0.0.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "tsx": "^4.20.1",
    "typescript": "^5.9.3"
  }
}
